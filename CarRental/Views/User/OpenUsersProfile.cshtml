
<style>
    .account-analytics-section {
        margin-bottom: 45px !important;
    }

   
    #profileSliderWrapper {
        position: relative;
        display: flex;
        align-items: center;
        width: 100%;
        padding: 0 10px;
        box-sizing: border-box;
        margin-bottom: 10px;
    }

    
    #profileCarSlider {
        display: flex;
        gap: 15px;
        overflow-x: hidden;
        scroll-behavior: smooth;
        width: 100%;
        padding: 15px 5px;
    }

   
    #profileSliderWrapper .view-car-car-card {
        min-width: 190px;
        max-width: 190px;
        flex-shrink: 0;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        box-sizing: border-box;
    }

    #profileSliderWrapper .view-car-car-image {
        width: 100%;
        height: 110px;
        object-fit: cover;
        border-radius: 8px;
    }

    #profileSliderWrapper .view-car-car-info h4 {
        margin: 8px 0 4px 0;
        font-size: 15px;
        color: #211066;
        font-weight: 700;
    }

    #profileSliderWrapper .view-car-car-info p {
        margin: 2px 0;
        font-size: 12px;
        color: #4b5563;
    }

    #profileSliderWrapper .slider-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
      
        background-color: #211066;
        color: white;
        border: none;
        border-radius: 50%;
        width: 35px;
        height: 35px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        transition: background-color 0.2s ease;
    }

        #profileSliderWrapper .slider-btn:hover {
            background-color: #2563eb;
            
        }

    #profileSliderWrapper .prev-btn {
        left: 0;
    }

    #profileSliderWrapper .next-btn {
        right: 0;
    }
</style>

<div class="profile-page-layout">

    <div class="profile-column">

        <section class="profile-personal-info-card">
            <h3>Personal Information</h3>
            <div class="profile-content">

                <div class="profile-left">
                    <img class="profile-picture-img" src="/images/profile-picture.png" alt="Profile Picture" />

                    @if (Model is Owner)
                    {
                        <div class="owner-badge">
                            <h4>Owner Profile</h4>
                            <p>Verified Car Provider</p>
                        </div>
                    }
                </div>

                <div class="personal-info">
                    <p><strong>First Name:</strong> @Model.User.FirstName</p>
                    <p><strong>Last Name:</strong> @Model.User.LastName</p>
                    <p><strong>Email:</strong> @Model.User.Email</p>
                    <p><strong>Phone:</strong> @Model.User.PhoneNumber</p>
                </div>

                @if (!User.IsInRole("Admin"))
                {
                    <form asp-controller="User" asp-action="ReportUser" method="post" style="display:inline;">
                        <input type="hidden" name="recipientId" value="@Model.User.Id" />
                        <button type="submit" class="report-btn" onclick="return confirm('Are you sure you want to report this user?');">
                            Report
                        </button>
                    </form>
                }

            </div>
        </section>
    @if (Model is Owner ownerEntity)
{
    <div class="account-analytics-section">
        <h3>Owner's Vehicles</h3>

        <div class="slider-container">
            @if (ownerEntity.Vehicles == null || !ownerEntity.Vehicles.Any())
            {
                <div class="view-car-empty">
                    No cars found for this owner.
                </div>
            }
            else
            {
                <div class="slider-wrapper" id="profileSliderWrapper">
                    <button class="slider-btn prev-btn" onclick="scrollProfileSlider(-1)">&#10094;</button>
                    
                    <div class="view-car-cars-slider" id="profileCarSlider">
                        @foreach (var car in ownerEntity.Vehicles)
                        {
                            <div class="view-car-car-card" data-id="@car.VehicleId">
                                <img src="@car.Image" class="view-car-car-image" />

                                <div class="view-car-car-content">
                                    <div class="view-car-car-info">
                                        <h4>@car.Make @car.Model</h4>
                                        <p><b>Year:</b> @car.Year</p>
                                        <p><b>Cubic:</b> @car.Cubic cc</p>
                                        <p class="car-price"><b>Price/Day:</b> @car.PricePerDay €</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    
                    <button class="slider-btn next-btn" onclick="scrollProfileSlider(1)">&#10095;</button>
                </div>
            }
        </div>
    </div>
}
        <script>
                    function scrollProfileSlider(direction) {
                        const slider = document.getElementById('profileCarSlider');
                        const scrollAmount = 205;

                        slider.scrollBy({
                            left: direction * scrollAmount
                        });
                    }
        </script>
        @if (User.IsInRole("Admin"))
        {
            <section class="leave-review-section admin-suspend-section">
                <h3>Manage User Access</h3>

                @if (Model.User.IsSuspended)
                {
                    <div style="text-align: center; margin-top: 10px;">
                        <p style="color: #742a2a; font-weight: 600; margin-bottom: 20px; font-size: 16px;">
                            Suspended untill
                            <span style="text-decoration: underline;">@Model.User.SuspensionEnd.ToString("dd/MM/yyyy")</span>
                        </p>

                        <form asp-controller="Admin" asp-action="LiftSuspension" method="post">
                            <input type="hidden" name="UserId" value="@Model.User.Id" />

                            <button type="submit" class="submit-lift-btn">
                                 Lift Suspension 
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <form asp-controller="Admin" asp-action="SuspendUser" method="post">
                        <input type="hidden" name="UserId" value="@Model.User.Id" />

                        <div class="form-group">
                            <label>Suspend Until :</label>
                            <input type="date" name="date" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>

                        <button type="submit" class="submit-suspend-btn">
                            Suspend User
                        </button>
                    </form>
                }

                @if (ViewBag.StartDate != null && ViewBag.EndDate != null)
                {
                    <div class="booking-period-box">
                        <strong>Booking period:</strong>
                        <span>
                            @Convert.ToDateTime(ViewBag.StartDate).ToString("dd/MM/yyyy HH:mm")
                            -
                            @Convert.ToDateTime(ViewBag.EndDate).ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </div>
                }
            </section>
        }
        else
        {
            <section class="leave-review-section">
                <h3>Leave a Review</h3>
                <form asp-controller="Reviews" asp-action="AddReview" method="post">
                    <input type="hidden" name="recipientId" value="@Model.User.Id" />

                    <div class="form-group">
                        <label>Rating (1-5)</label>
                        <input type="number" name="rating" min="1" max="5" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Your Comment</label>
                        <textarea name="comment" class="form-control" rows="4"></textarea>
                    </div>

                    <button type="submit" class="submit-review-btn">
                        Submit Review
                    </button>
                </form>
            </section>
        }

    </div> <div class="reviews-column">
    <section class="reviews-section">
        <h3>Reviews</h3>

        @if (ViewBag.Reviews != null)
        {
            <div class="reviews-container">
                @foreach (var reviewItem in ViewBag.Reviews)
                {
                    <div class="review-card">
                        <div class="review-header">
                            <div class="review-name">
                                @reviewItem.Commenter.FirstName @reviewItem.Commenter.LastName
                            </div>
                            <div class="review-rating">
                                ⭐ @reviewItem.Rating/5
                            </div>
                        </div>
                        <div class="review-comment">
                            @reviewItem.Comment
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p>No reviews yet.</p>
        }
    </section>
</div></div>