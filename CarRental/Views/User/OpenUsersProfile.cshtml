<div class="profile-page-layout">

    <div class="profile-column">

        <section class="profile-personal-info-card">
            <h3>Personal Information</h3>
            <div class="profile-content">

                <div class="profile-left">
                    <img class="profile-picture-img" src="/images/profile-picture.png" alt="Profile Picture" />

                    @if (Model is Owner)
                    {
                        <div class="owner-badge">
                            <h4>Owner Profile</h4>
                            <p>Verified Car Provider</p>
                        </div>
                    }
                </div>

                <div class="personal-info">
                    <p><strong>First Name:</strong> @Model.User.FirstName</p>
                    <p><strong>Last Name:</strong> @Model.User.LastName</p>
                    <p><strong>Email:</strong> @Model.User.Email</p>
                    <p><strong>Phone:</strong> @Model.User.PhoneNumber</p>
                </div>

                @if (!User.IsInRole("Admin"))
                {
                    <button type="button" class="report-btn" onclick="openReportModal()">
                        Report User
                    </button>

                    <div id="reportModal" class="report-modal-overlay" style="display: none;">
                        <div class="report-modal-content">
                            <div class="report-modal-header">
                                <h3>Report Form</h3>
                                <span class="close-modal-btn" onclick="closeReportModal()">&times;</span>
                            </div>

                            <form asp-controller="User" asp-action="ReportUser" method="post">
                                <input type="hidden" name="recipientId" value="@Model.User.Id" />

                                <div class="form-group" style="margin-top: 15px;">
                                    <label style="display:block; margin-bottom: 5px; font-weight:600;">Description for report:</label>
                                    <textarea name="description" class="form-control" rows="5" required
                                              placeholder="Please describe why you are reporting this user..."></textarea>
                                </div>

                                <div class="report-modal-actions">
                                    <button type="button" class="btn-cancel-modal" onclick="closeReportModal()">Cancel</button>
                                    <button type="submit" class="btn-submit-modal">Submit Report</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }

            </div>
        </section>

        <section class="account-analytics-section" style="margin-top: 20px; background: #ffffff; border-radius: 16px; padding: 24px; border: 1px solid #e5e7eb; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);">
            <h3>Account Analytics</h3>
            <div class="analytics-grid">

                @if (!User.IsInRole("Admin"))
                {
                    <div class="analytics-card rating-card">
                        <div class="analytics-info">
                            <h4>@ViewBag.AverageRating</h4>
                            <p>Average Rating</p>
                        </div>
                    </div>

                    <div class="analytics-card alert-card">
                        <div class="analytics-info">
                            <h4>@ViewBag.ReportsReceivedCount</h4>
                            <p>Times Reported</p>
                        </div>
                    </div>
                }

                @if (Model is Renter && ViewBag.RenterTotalBookings != null)
                {
                    <div class="analytics-card renter-stat">
                        <div class="analytics-info">
                            <h4>@ViewBag.RenterTotalBookings Bookings</h4>
                            <p>Total Bookings</p>
                        </div>
                    </div>
                    <div class="analytics-card renter-stat">
                        <div class="analytics-info">
                            <h4>@ViewBag.RenterTotalDays Days</h4>
                            <p>Total Days Rented</p>
                        </div>
                    </div>
                }

                @if (Model is Owner && ViewBag.OwnerTotalCars != null)
                {
                    <div class="analytics-card owner-stat">
                        <div class="analytics-info">
                            <h4>@ViewBag.OwnerTotalCars Cars</h4>
                            <p>Fleet Size</p>
                        </div>
                    </div>
                    <div class="analytics-card owner-stat">
                        <div class="analytics-info">
                            <h4>@ViewBag.OwnerTotalDeals Deals</h4>
                            <p>Successful Deals</p>
                        </div>
                    </div>
                }
            </div>
        </section>
        @if (Model is Owner ownerEntity)
        {
            <div class="account-analytics-section" style="margin-top: 20px;">
                <h3>Owner's Available Vehicles</h3>

                <div class="slider-container">
                    @if (ownerEntity.Vehicles == null || !ownerEntity.Vehicles.Any())
                    {
                        <div class="view-car-empty">
                            There are no available cars from this owner at this time.
                        </div>
                    }
                    else
                    {
                        <div class="slider-wrapper" id="profileSliderWrapper">
                            <button class="slider-btn prev-btn" onclick="scrollProfileSlider(-1)">&#10094;</button>

                            <div class="view-car-cars-slider" id="profileCarSlider">
                                @foreach (var car in ownerEntity.Vehicles)
                                {
                                    <div class="view-car-car-card" data-id="@car.VehicleId">
                                        <img src="@car.Image" class="view-car-car-image" />

                                        <div class="view-car-car-content">
                                            <div class="view-car-car-info">
                                                <h4>@car.Make @car.Model</h4>
                                                <p><b>Year:</b> @car.Year</p>
                                                <p><b>Cubic:</b> @car.Cubic cc</p>
                                                <p class="car-price"><b>Price/Day:</b> @car.PricePerDay €</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <button class="slider-btn next-btn" onclick="scrollProfileSlider(1)">&#10095;</button>
                        </div>
                    }
                </div>
            </div>
        }

        <script>
                    function scrollProfileSlider(direction) {
                        const slider = document.getElementById('profileCarSlider');
                        const scrollAmount = 205;

                        slider.scrollBy({
                            left: direction * scrollAmount
                        });
                    }
        </script>

        @if (User.IsInRole("Admin"))
        {
            <section class="leave-review-section admin-suspend-section" style="margin-top: 20px;">
                <h3>Manage User Access</h3>

                @if (Model.User.IsSuspended)
                {
                    <div style="text-align: center; margin-top: 10px;">
                        <p style="color: #742a2a; font-weight: 600; margin-bottom: 20px; font-size: 16px;">
                            Suspended until
                            <span style="text-decoration: underline;">@Model.User.SuspensionEnd.ToString("dd/MM/yyyy")</span>
                        </p>

                        <form asp-controller="Admin" asp-action="LiftSuspension" method="post">
                            <input type="hidden" name="UserId" value="@Model.User.Id" />

                            <button type="submit" class="submit-lift-btn">
                                Lift Suspension
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <form asp-controller="Admin" asp-action="SuspendUser" method="post">
                        <input type="hidden" name="UserId" value="@Model.User.Id" />

                        <div class="form-group">
                            <label>Suspend Until :</label>
                            <input type="date" name="date" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>

                        <button type="submit" class="submit-suspend-btn">
                            Suspend User
                        </button>
                    </form>
                }

                @if (ViewBag.StartDate != null && ViewBag.EndDate != null)
                {
                    <div class="booking-period-box">
                        <strong>Booking period:</strong>
                        <span>
                            @Convert.ToDateTime(ViewBag.StartDate).ToString("dd/MM/yyyy HH:mm")
                            -
                            @Convert.ToDateTime(ViewBag.EndDate).ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </div>
                }
            </section>
        }

    </div>

    <div class="reviews-column">
        <section class="reviews-section">
            <h3>Reviews</h3>

            @if (ViewBag.Reviews != null)
            {
                <div class="reviews-container">
                    @foreach (var reviewItem in ViewBag.Reviews)
                    {
                        <div class="review-card">
                            <div class="review-header">
                                <div class="review-name">
                                    @reviewItem.Commenter.FirstName @reviewItem.Commenter.LastName
                                </div>
                                <div class="review-rating">
                                    ⭐ @reviewItem.Rating/5
                                </div>
                            </div>
                            <div class="review-comment">
                                @reviewItem.Comment
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p>No reviews yet.</p>
            }
        </section>

        @if (!User.IsInRole("Admin")){
            <section class="leave-review-section">
                <h3>Leave a Review</h3>
                <form asp-controller="Reviews" asp-action="AddReview" method="post">
                    <input type="hidden" name="recipientId" value="@Model.User.Id" />

                    <div class="form-group">
                        <label>Rating (1-5)</label>
                        <input type="number" name="rating" min="1" max="5" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Your Comment</label>
                        <textarea name="comment" class="form-control" rows="4"></textarea>
                    </div>

                    <button type="submit" class="submit-review-btn">
                        Submit Review
                    </button>
                </form>
            </section>
        }
    </div>
</div>

<style>
    .analytics-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin-top: 15px;
    }

    .analytics-card {
        display: flex;
        align-items: center;
        padding: 15px 20px;
        background: #f8fafc;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        border-left: 5px solid #cbd5e1;
    }

    .rating-card {
        border-left-color: #eab308;
    }

    .alert-card {
        border-left-color: #ef4444;
    }

    .renter-stat {
        border-left-color: #3b82f6;
    }

    .owner-stat {
        border-left-color: #10b981;
    }

    .analytics-info h4 {
        margin: 0;
        font-size: 18px;
        color: #211066;
        font-weight: 700;
    }

    .analytics-info p {
        margin: 4px 0 0 0;
        font-size: 11px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

   
    }
</style>

<script>
    function openReportModal() {
        document.getElementById('reportModal').style.display = 'flex';
    }
    function closeReportModal() {
        document.getElementById('reportModal').style.display = 'none';
    }

    window.onclick = function(event) {
        const modal = document.getElementById('reportModal');
        if (event.target == modal) {
            modal.style.display = 'none';
        }
    }
</script>