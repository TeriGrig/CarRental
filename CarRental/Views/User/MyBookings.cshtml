@model List<CarRental.Models.Booking>

@{
    var archivedBookings = Model
        .Where(b =>
            b.Status == "Cancelled"
            || b.Status == "Rejected"
            || b.EndDate < DateTime.Now)
        .ToList();

    var activeBookings = Model
        .Where(b =>
            (b.Status == "Accepted"
            || b.Status == "Requested")
            && b.EndDate >= DateTime.Now)
        .ToList();
}


<div class="my-bookings">

    <!-- LEFT: ACTIVE -->
    <div class="bookings-column">

        <div class="booking-section">

            <h2>Active Bookings</h2>

            @if (activeBookings.Count == 0)
            {
                <p>No active bookings.</p>
            }

            @foreach (var booking in activeBookings)
            {
                <div class="booking-card">

                    @if (User.IsInRole("Owner"))
                    {
                        <h4>
                            Booking made for @booking.Vehicle.Make
                            @booking.Vehicle.Model by user

                            <a asp-controller="User"
                                   asp-action="OpenUsersProfile"
                                   asp-route-userId="@booking.Renter.UserId">

                                @booking.Renter.User.FirstName
                                @booking.Renter.User.LastName

                            </a>
                        </h4>
                    }

                    @if (User.IsInRole("Renter"))
                    {
                        <h4>
                            Booking for vehicle @booking.Vehicle.Make
                            @booking.Vehicle.Model owned by

                            <a asp-controller="User"
                                   asp-action="OpenUsersProfile"
                                   asp-route-userId="@booking.Vehicle.Owner.UserId">

                                @booking.Vehicle.Owner.User.FirstName
                                @booking.Vehicle.Owner.User.LastName

                            </a>
                        </h4>
                    }

                    <p>
                        Dates:
                        @booking.StartDate.ToShortDateString()
                        -
                        @booking.EndDate.ToShortDateString()
                    </p>

                    <p>Status: @booking.Status</p>

                </div>
            }

        </div>
    </div>

    <!-- RIGHT: ARCHIVED -->
    <div class="bookings-column">

        <div class="booking-section">

            <h2>Archived Bookings</h2>

            @if (archivedBookings.Count == 0)
            {
                <p>No archived bookings.</p>
            }

            @foreach (var booking in archivedBookings)
            {
                <div class="booking-card archived">

                    <h4>
                        Booking for @booking.Vehicle.Make
                        @booking.Vehicle.Model
                    </h4>

                    <p>
                        Dates:
                        @booking.StartDate.ToShortDateString()
                        -
                        @booking.EndDate.ToShortDateString()
                    </p>

                    <p>Status: @booking.Status</p>

                </div>
            }

        </div>

    </div>

</div>


