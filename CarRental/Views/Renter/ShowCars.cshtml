@model List<CarRental.Models.Vehicle>

<link rel="stylesheet"
      href="https://unpkg.com/leaflet/dist/leaflet.css" />

<h2>Available Cars</h2>

<div class="cars-map-layout">

    <!-- Map -->
    <div id="map" class="cars-map"></div>

    <!-- Cars -->
    <div class="cars-list">

        @if (!Model.Any())
        {
            <div class="alert alert-warning">
                No cars found.
            </div>
        }

        @foreach (var car in Model)
        {
            <div class="car-list-card"
                 onclick="focusCar(@car.Latitude, @car.Longitude)">

                <img src="@car.Image" class="car-list-image" />

                <div class="car-list-body">

                    <div class="car-info">
                        <h4>@car.Make @car.Model</h4>

                        <p><b>Year:</b> @car.Year<br>
                            <b>Cubic:</b> @car.Cubic<br>
                        <b>Price/Day:</b> @car.PricePerDay €</p>
                    </div>

                    <form method="post" action="/Renter/Book" class="car-actions">
                        <input type="hidden" name="vehicleId" value="@car.VehicleId" />
                        <button type="submit" class="show-car-btn">Book</button>
                    </form>

                </div>
            </div>
        }

    </div>
</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>

    let map;
    let markers = [];

    document.addEventListener("DOMContentLoaded", function () {

    map = L.map('map').setView([37.9838, 23.7275], 7);

    L.tileLayer(
    'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
    {
    maxZoom: 19,
    attribution: '&copy; OpenStreetMap'
    }
    ).addTo(map);

    @foreach (var car in Model)
    {
        if (car.Latitude != 0 && car.Longitude != 0)
        {
            <text>
                var marker = L.marker([
                @car.Latitude,
                @car.Longitude
                ])
                .addTo(map)
                .bindPopup(`
                <b>@car.Make @car.Model</b><br>
                Price: @car.PricePerDay € / day
                `);

                markers.push(marker);
            </text>
        }
    }
    });

    function focusCar(lat, lng) {

    if (lat === 0 || lng === 0)
    return;

    map.setView([lat, lng], 14);

    markers.forEach(m => {
    var pos = m.getLatLng();

    if (pos.lat === lat && pos.lng === lng) {
    m.openPopup();
    }
    });
    }

</script>