@model CarRental.Models.Vehicle
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

<div class="book-page-layout">
    <div class="book-car-section">

        <h3>
            Your booking for @Model.Make @Model.Model from
            <a asp-controller="User"
               asp-action="OpenUsersProfile"
               asp-route-userId="@Model.Owner.UserId">
                @Model.Owner.User.FirstName @Model.Owner.User.LastName
            </a>
        </h3>

        <div class="car-details-row">
            <img src="@Model.Image" class="book-car-image" />

            <div class="book-car-info">
                <p>
                    <b>Year:</b> @Model.Year<br>
                    <b>Cubic:</b> @Model.Cubic<br>
                    <b>Price/Day:</b> @Model.PricePerDay €<br>
                    <b>Comments:</b> @Model.Comments
                </p>
                
            </div>
        </div>
        <p class="booking-address">
            <strong>Location Address:</strong> <span id="addressText">Loading address...</span>
        </p>
        <div id="bookCarMap" class="book-car-map" data-lat="@Model.Latitude" data-lng="@Model.Longitude">
            <button id="resetMapBtn"
                    style="position:absolute; bottom:10px; left:10px; z-index:1000;
                background:white; border:1px solid #ccc;
                padding:6px 10px; border-radius:6px; cursor:pointer;">
                Reset Map
            </button>
        </div>
       

        <div class="booking-form-section">
            <form method="post" action="/Renter/CreateBooking">
                <input type="hidden" name="vehicleId" value="@Model.VehicleId" />
                <input type="hidden" name="startDate" value="@ViewBag.StartDate" />
                <input type="hidden" name="endDate" value="@ViewBag.EndDate" />

                <div class="booking-period-inline">
                    <strong>Booking period:</strong>
                    <span>
                        @Convert.ToDateTime(ViewBag.StartDate).ToString("dd/MM/yyyy HH:mm")
                        -
                        @Convert.ToDateTime(ViewBag.EndDate).ToString("dd/MM/yyyy HH:mm")
                    </span>
                </div>

                <button type="submit" class="show-car-btn">
                    Request Booking
                </button>
            </form>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
    // Reusable address fetch function
    async function getAddress(lat, lon) {
    try {
    const response = await fetch(
    `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`
    );
    const data = await response.json();
    const address = data.address;

    if (!address) return "Address not found";

    const road = address.road || address.pedestrian || address.footway || "Unknown street";
    const houseNumber = address.house_number || "";
    const postcode = address.postcode || "Unknown postal code";
    const region = address.state || address.region || address.county || "Unknown region";

    return `${road} ${houseNumber}, ${postcode}, ${region}`;
    } catch (error) {
    return "Address not found";
    }
    }

    // FIXED HERE: Unified single script execution loop
    document.addEventListener("DOMContentLoaded", function () {
    // Read directly from C# Model values instead of fragile data-attributes
    var lat = @Model.Latitude;
    var lng = @Model.Longitude;

    const addressTextSpan = document.getElementById("addressText");

    if (lat !== 0 && lng !== 0) {
    // 1. Initialize Map
    var map = L.map('bookCarMap').setView([lat, lng], 13);

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; OpenStreetMap'
    }).addTo(map);

    L.marker([lat, lng])
    .addTo(map)
    .bindPopup(`<b>@Model.Make @Model.Model</b>`)
    .openPopup();

    document.getElementById("resetMapBtn").addEventListener("click", function () {
    map.flyTo([lat, lng], 13, { // Fixed to reset back to car location, not center of Athens
    animate: true,
    duration: 1.2
    });
    });

    setTimeout(() => {
    map.invalidateSize();
    }, 100);

    // 2. Fetch and display Address text
    if (addressTextSpan) {
    getAddress(lat, lng).then(readableAddress => {
    addressTextSpan.innerHTML = readableAddress;
    });
    }
    } else {
    if (addressTextSpan) {
    addressTextSpan.textContent = "No coordinates available";
    }
    }
    });
</script>